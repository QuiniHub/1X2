<!DOCTYPE html>
<html lang="es"><head><meta charset="UTF-8"/><meta name="viewport" content="width=device-width, initial-scale=1.0"/>
<title>Quiniela IA Pro Completo</title>
<style>
:root{--bg:#f5f7fb;--card:#fff;--text:#132033;--muted:#667085;--line:#e6e9f0;--brand:#0f2e4f;--green:#1f7a4c;--red:#b42318;--orange:#b54708;--blue:#1d4ed8}
*{box-sizing:border-box}body{margin:0;font-family:Arial,Helvetica,sans-serif;background:var(--bg);color:var(--text)}
header{background:linear-gradient(135deg,#0f2e4f,#1f7a4c);color:white;padding:34px 22px}.wrap{max-width:1240px;margin:0 auto}
h1{margin:8px 0;font-size:36px}main{padding:22px}.card{background:white;border:1px solid var(--line);border-radius:22px;padding:20px;box-shadow:0 10px 30px rgba(17,24,39,.08)}
.grid{display:grid;gap:16px}.stats{grid-template-columns:repeat(4,1fr)}.two{grid-template-columns:1fr 1fr}.three{grid-template-columns:repeat(3,1fr)}
.badge{display:inline-block;border-radius:999px;padding:5px 10px;font-size:12px;font-weight:700;background:#eef4ff;color:var(--brand)}
.green{background:#ecfdf3;color:var(--green)}.orange{background:#fff7ed;color:var(--orange)}.red{background:#fef3f2;color:var(--red)}.blue{background:#eff6ff;color:var(--blue)}
button{border:0;border-radius:14px;padding:11px 14px;font-weight:700;cursor:pointer;background:var(--brand);color:white}button.secondary{background:white;color:var(--brand)}
.toolbar,.tabs{display:flex;gap:10px;flex-wrap:wrap;margin-top:18px}.tabs{margin:20px 0}.tab{background:white;color:var(--text);border:1px solid var(--line)}.tab.active{background:var(--brand);color:white}
.section{display:none}.section.active{display:block}.match{border:1px solid var(--line);border-radius:18px;padding:15px;margin-bottom:12px;background:white}.triple{border-left:7px solid var(--red)}.doble{border-left:7px solid var(--orange)}.fijo{border-left:7px solid var(--green)}
.top{display:flex;justify-content:space-between;gap:14px;align-items:flex-start}.sign{font-size:25px;font-weight:900;color:var(--brand);white-space:nowrap}
.small{color:var(--muted);font-size:13px}.bar{height:9px;background:#edf0f6;border-radius:999px;overflow:hidden;margin-top:8px}.fill{height:100%;background:var(--brand)}
table{width:100%;border-collapse:collapse;background:white}th,td{border-bottom:1px solid var(--line);padding:10px;text-align:left;font-size:14px;vertical-align:top}th{font-size:12px;text-transform:uppercase;color:var(--muted)}
input{width:100%;border:1px solid var(--line);border-radius:14px;padding:11px;font-size:14px}.notice{border-left:5px solid var(--orange);background:#fffaf4}.good{border-left:5px solid var(--green);background:#f6fffa}.footer{text-align:center;color:var(--muted);font-size:13px;padding:20px 20px 38px}
@media(max-width:900px){.stats,.two,.three{grid-template-columns:1fr}h1{font-size:28px}.top{flex-direction:column}}
</style></head><body>
<header><div class="wrap"><span class="badge green">GitHub completo</span><h1>Quiniela IA Pro Completo</h1><p>App preparada para quinielas, Elige 8, histórico, Eduardo Losilla, datos avanzados, automatización y machine learning.</p><div class="toolbar"><button onclick="window.print()">Imprimir</button><button class="secondary" onclick="downloadReport()">Descargar informe</button></div></div></header>
<main class="wrap">
<div class="grid stats"><div class="card"><span class="small">Módulos</span><h2>15</h2><p class="small">Full Pro</p></div><div class="card"><span class="small">Jornada</span><h2>61</h2><p class="small">3T + 2D</p></div><div class="card"><span class="small">Histórico</span><h2>Activo</h2><p class="small">Boletos y premios</p></div><div class="card"><span class="small">Auto</span><h2>GitHub</h2><p class="small">Cada lunes</p></div></div>
<div class="tabs"><button class="tab active" onclick="showTab('quiniela',this)">Quiniela</button><button class="tab" onclick="showTab('elige8',this)">Elige 8</button><button class="tab" onclick="showTab('historico',this)">Histórico</button><button class="tab" onclick="showTab('fuentes',this)">Fuentes</button><button class="tab" onclick="showTab('equipos',this)">Equipos</button><button class="tab" onclick="showTab('auto',this)">GitHub</button></div>

<section id="quiniela" class="section active"><div class="grid two"><div class="card"><h2>Pronóstico actual</h2><div id="matches"></div></div><div class="card notice"><h2>Lectura estratégica</h2><p><b>Triples:</b> Elche-Alavés, Real Sociedad-Betis, Rayo-Girona.</p><p><b>Dobles:</b> Mallorca-Villarreal 1X y Burgos-Almería X2.</p><p><b>Bombas:</b> Sevilla-Espanyol X, Andorra-Las Palmas X, Leganés-Racing 2.</p><p><b>Eduardo Losilla:</b> módulo preparado para comparar consenso y valor contrario.</p></div></div></section>

<section id="elige8" class="section"><div class="card"><h2>Elige 8</h2><table><thead><tr><th>Partido</th><th>Tipo</th><th>Signo</th><th>Motivo</th></tr></thead><tbody id="eligeRows"></tbody></table></div></section>

<section id="historico" class="section"><div class="grid two"><div class="card good"><h2>Histórico de quinielas</h2><ul><li>Resultados oficiales jornada a jornada</li><li>Signos 1/X/2</li><li>Pleno al 15</li><li>Recaudación, bote y premios</li><li>Frecuencia de X</li><li>Favoritos fallidos</li><li>Sorpresas reales</li><li>Rentabilidad de boletos</li></ul></div><div class="card"><h2>Boletos generados</h2><table><thead><tr><th>ID</th><th>Estrategia</th><th>Coste</th><th>Estado</th></tr></thead><tbody id="boletosRows"></tbody></table></div></div></section>

<section id="fuentes" class="section"><div class="card"><h2>Fuentes y módulos</h2><table><thead><tr><th>Módulo</th><th>Fuente</th><th>Coste</th><th>Datos</th></tr></thead><tbody id="providersRows"></tbody></table></div></section>

<section id="equipos" class="section"><div class="card"><h2>Dinámicas de equipos</h2><input id="teamSearch" placeholder="Buscar equipo..." oninput="renderTeams()"/><div id="teams" class="grid three" style="margin-top:16px"></div></div></section>

<section id="auto" class="section"><div class="grid two"><div class="card good"><h2>Qué subir a GitHub</h2><p>Descomprime el ZIP y sube TODO el contenido:</p><ul><li>index.html</li><li>data/</li><li>scripts/</li><li>docs/</li><li>.github/workflows/</li><li>README.md</li></ul></div><div class="card notice"><h2>Actualización automática</h2><p>El archivo <b>.github/workflows/actualizar-quiniela.yml</b> ejecuta <b>scripts/actualizar_todo.py</b> cada lunes.</p><p>Para datos premium añade Secrets: THE_ODDS_API_KEY, API_FOOTBALL_KEY, SPORTMONKS_KEY.</p></div></div></section>
</main><div class="footer">Quiniela IA Pro Completo</div>
<script>
const matches = [[1, "Elche", "Alavés", "1X2", "TRIPLE", 92, "descenso", "alta", "pendiente", "pendiente", "pendiente", "pendiente", "pendiente", "Descenso directo; ansiedad máxima; tres escenarios reales."], [2, "Sevilla", "Espanyol", "X", "FIJO", 74, "permanencia", "muy alta", "pendiente", "pendiente", "pendiente", "pendiente", "pendiente", "Favorito vulnerable; bloqueo psicológico; X de valor."], [3, "Atlético de Madrid", "Celta", "1", "FIJO", 80, "Champions/Europa", "media", "pendiente", "pendiente", "pendiente", "pendiente", "pendiente", "Metropolitano + objetivo Champions; pilar sólido."], [4, "Real Sociedad", "Betis", "1X2", "TRIPLE", 91, "Europa", "alta", "pendiente", "pendiente", "pendiente", "pendiente", "pendiente", "Partido técnico, abierto y muy quinielero."], [5, "Mallorca", "Villarreal", "1X", "DOBLE", 86, "permanencia_vs_champions", "muy alta", "pendiente", "pendiente", "pendiente", "pendiente", "pendiente", "Mallorca más necesitado; posible bomba anti-favorito."], [6, "Athletic Club", "Valencia", "1", "FIJO", 72, "Europa_vs_permanencia", "media-alta", "pendiente", "pendiente", "pendiente", "pendiente", "pendiente", "San Mamés + empuje local."], [7, "Oviedo", "Getafe", "X", "FIJO", 78, "supervivencia", "alta", "pendiente", "pendiente", "pendiente", "pendiente", "pendiente", "Partido feo, físico y de bloqueo psicológico."], [8, "Rayo Vallecano", "Girona", "1X2", "TRIPLE", 90, "zona_media/salvacion", "muy alta", "pendiente", "pendiente", "pendiente", "pendiente", "pendiente", "Caos, ida y vuelta, partido de guion roto."], [9, "Ceuta", "Castellón", "2", "FIJO", 65, "playoff/ascenso", "media", "pendiente", "pendiente", "pendiente", "pendiente", "pendiente", "Castellón con objetivo fuerte; signo diferencial visitante."], [10, "Burgos", "Almería", "X2", "DOBLE", 84, "playoff_vs_ascenso", "alta", "pendiente", "pendiente", "pendiente", "pendiente", "pendiente", "Burgos fuerte en casa; Almería obligado al ascenso."], [11, "Málaga", "Sporting", "1", "FIJO", 75, "playoff", "media", "pendiente", "pendiente", "pendiente", "pendiente", "pendiente", "Málaga con mejor dinámica y localía."], [12, "Andorra", "Las Palmas", "X", "FIJO", 71, "playoff/ascenso", "media-alta", "pendiente", "pendiente", "pendiente", "pendiente", "pendiente", "Control, miedo a perder y empate útil."], [13, "Leganés", "Racing Santander", "2", "FIJO", 76, "salvacion_vs_ascenso", "media-alta", "pendiente", "pendiente", "pendiente", "pendiente", "pendiente", "Racing con objetivo enorme; signo diferencial."], [14, "Córdoba", "Granada", "1", "FIJO", 73, "playoff/reenganche", "media", "pendiente", "pendiente", "pendiente", "pendiente", "pendiente", "Córdoba más enchufado y con hambre competitiva."], [15, "Barcelona", "Real Madrid", "M-1", "PLENO", 51, "titulo/orgullo", "muy alta", "pendiente", "pendiente", "pendiente", "pendiente", "pendiente", "Clásico abierto; marcador emocional 2-1."]];
const elige8 = [["Elche - Alavés", "TRIPLE", "1X2", "Caos descenso"], ["Real Sociedad - Betis", "TRIPLE", "1X2", "Europa e imprevisibilidad"], ["Rayo - Girona", "TRIPLE", "1X2", "Partido de caos"], ["Mallorca - Villarreal", "DOBLE", "1X", "Bomba anti-favorito"], ["Burgos - Almería", "DOBLE", "X2", "Ascenso + presión"], ["Atlético - Celta", "FIJO", "1", "Pilar fuerte"], ["Málaga - Sporting", "FIJO", "1", "Dinámica local"], ["Córdoba - Granada", "FIJO", "1", "Hambre competitiva"]];
const providers = [["histórico_boletos_quiniela", "SELAE / Loterías / histórico autorizado", "depende disponibilidad", "Resultados oficiales, premios, recaudación, botes y signos por jornada", "scripts/actualizar_historico_boletos.py"], ["eduardo_losilla", "https://www.eduardolosilla.es/", "web pública, respetar condiciones", "Quinielas publicadas, análisis, sorpresas, signos recomendados", "scripts/actualizar_eduardo_losilla.py"], ["porcentajes_apostados", "SELAE si lo publica / scraping autorizado", "depende disponibilidad", "Distribución apostada por signo", "scripts/actualizar_porcentajes_apostados.py"], ["resultados_historicos_futbol", "Football-Data", "gratis", "Resultados, estadísticas, cuotas históricas de Primera y Segunda", "scripts/actualizar_resultados.py"], ["cuotas_tiempo_real", "The Odds API / Odds-API.io", "normalmente pago o limitado", "Cuotas de mercado por partido", "scripts/actualizar_cuotas.py"], ["lesiones_sanciones_alineaciones", "API-Football / Sportmonks", "normalmente pago", "Bajas, sanciones y once probable", "scripts/actualizar_plantillas.py"], ["xg", "FootyStats / proveedor xG", "normalmente pago", "xG, xGA, tiros, ocasiones", "scripts/actualizar_xg.py"], ["arbitros", "BDFutbol / RFEF / proveedor", "depende disponibilidad", "Tarjetas, penaltis, rojas, tendencia arbitral", "scripts/actualizar_arbitros.py"], ["clima", "Open-Meteo", "gratis", "Lluvia, viento, temperatura por estadio", "scripts/actualizar_clima.py"]];
const teams = [["Barcelona", "1a", "muy alta", "cierre de titulo", "estable", "favorito fiable pero con posible relajacion"], ["Real Madrid", "1a", "alta", "orgullo/recortar", "alta presion", "nunca descartable"], ["Atletico de Madrid", "1a", "alta", "Champions", "fuerte en casa", "pilar local"], ["Villarreal", "1a", "alta", "Champions/Europa", "calidad alta", "peligroso fuera ante desesperados"], ["Betis", "1a", "alta", "Europa", "emocional", "ideal para sorpresas y empates"], ["Real Sociedad", "1a", "media-alta", "Europa", "tactico", "empates vivos"], ["Athletic Club", "1a", "media-alta", "Europa", "muy fuerte local", "fijo local razonable"], ["Valencia", "1a", "alta", "permanencia", "fragil pero competitivo", "peligroso si resiste"], ["Sevilla", "1a", "muy alta", "permanencia", "ansioso", "favorito vulnerable"], ["Mallorca", "1a", "muy alta", "permanencia", "supervivencia", "bomba local/empate"], ["Girona", "1a", "media", "salvacion/ambicion", "abierto", "partidos caoticos"], ["Rayo Vallecano", "1a", "media-alta", "zona media/Europa", "intenso", "imprevisible"], ["Getafe", "1a", "media", "competir sin locura", "fisico", "empates"], ["Alaves", "1a", "muy alta", "descenso", "ansiedad", "puede romper logica"], ["Espanyol", "1a", "alta", "permanencia", "resistencia", "X valiosa"], ["Almeria", "2a", "muy alta", "ascenso directo", "presion", "calidad + ansiedad"], ["Racing Santander", "2a", "muy alta", "ascenso", "confianza", "visitante peligroso"], ["Burgos", "2a", "alta", "playoff", "fuerte casa", "trampa enorme"], ["Malaga", "2a", "alta", "playoff", "creciendo", "fijo local"], ["Las Palmas", "2a", "alta", "ascenso/playoff", "control", "muchos empates"], ["Leganes", "2a", "media-alta", "salvacion", "pragmatico", "partido corto"], ["Sporting", "2a", "media", "engancharse", "irregular", "poco fiable fuera"], ["Oviedo", "2a", "muy alta", "supervivencia", "ansiedad", "X/barro"], ["Cordoba", "2a", "alta", "playoff", "racha/hambre", "fijo con valor"], ["Granada", "2a", "media", "reenganche", "irregular", "talento peligroso"]];
const boletos = [["QIA-61-3T2D", "2025/26", "61", "3 triples + 2 dobles premio grande", "1X2,X,1,1X2,1X,1,X,1X2,2,X2,1,X,2,1", "M-1", "729", "", "", "", "Boleto generado por Quiniela IA Pro"]];
function typeClass(t){if(t==="TRIPLE")return"triple";if(t==="DOBLE")return"doble";return"fijo"}
function renderMatches(){document.getElementById("matches").innerHTML=matches.map(m=>`<div class="match ${typeClass(m[4])}"><div class="top"><div><strong>${m[0]}. ${m[1]} - ${m[2]}</strong><p>${m[13]}</p><p class="small">Lesiones: ${m[8]} · Cuotas: ${m[9]} · xG: ${m[10]} · Árbitro: ${m[11]} · Clima: ${m[12]}</p></div><div class="sign">${m[3]}</div></div><span class="badge ${m[4]==='TRIPLE'?'red':m[4]==='DOBLE'?'orange':'green'}">${m[4]}</span> <span class="badge blue">Índice ${m[5]}</span><div class="bar"><div class="fill" style="width:${m[5]}%"></div></div></div>`).join("")}
function renderElige(){document.getElementById("eligeRows").innerHTML=elige8.map(e=>`<tr><td>${e[0]}</td><td><span class="badge ${e[1]==='TRIPLE'?'red':e[1]==='DOBLE'?'orange':'green'}">${e[1]}</span></td><td class="sign">${e[2]}</td><td>${e[3]}</td></tr>`).join("")}
function renderProviders(){document.getElementById("providersRows").innerHTML=providers.map(p=>`<tr><td>${p[0]}</td><td>${p[1]}</td><td>${p[2]}</td><td>${p[3]}</td></tr>`).join("")}
function renderBoletos(){document.getElementById("boletosRows").innerHTML=boletos.map(b=>`<tr><td>${b[0]}</td><td>${b[3]}</td><td>${b[6]} €</td><td>Pendiente resultado</td></tr>`).join("")}
function renderTeams(){const q=(document.getElementById("teamSearch")?.value||"").toLowerCase();document.getElementById("teams").innerHTML=teams.filter(t=>t.join(" ").toLowerCase().includes(q)).map(t=>`<div class="card"><h3>${t[0]}</h3><p class="small">${t[1]} · necesidad: ${t[2]}</p><p><b>Objetivo:</b> ${t[3]}</p><p><b>Ánimo:</b> ${t[4]}</p><p><b>Lectura:</b> ${t[5]}</p></div>`).join("")}
function showTab(id,btn){document.querySelectorAll(".section").forEach(s=>s.classList.remove("active"));document.querySelectorAll(".tab").forEach(t=>t.classList.remove("active"));document.getElementById(id).classList.add("active");btn.classList.add("active")}
function downloadReport(){const txt=`QUINIELA IA PRO COMPLETO\n\n${matches.map(m=>`${m[0]}. ${m[1]} - ${m[2]}: ${m[3]} (${m[4]})`).join("\n")}\n\nIncluye GitHub Actions, histórico, Eduardo Losilla, fuentes Pro y ML.`;const blob=new Blob([txt],{type:"text/plain;charset=utf-8"});const url=URL.createObjectURL(blob);const a=document.createElement("a");a.href=url;a.download="quiniela-ia-pro-informe.txt";a.click();URL.revokeObjectURL(url)}
renderMatches();renderElige();renderProviders();renderBoletos();renderTeams();
</script></body></html>
